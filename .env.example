# ─────────────────────────────────────────────────────────────────
# Lead Mining System — 环境变量模板
# 复制为 .env 并填入真实值后使用：cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── Phase 1: 核心 API Keys（必填）─────────────────────────────────
SERPER_API_KEY=your_serper_api_key_here        # https://serper.dev
HUNTER_API_KEY=your_hunter_api_key_here        # https://hunter.io → Dashboard → API （免费注册，25次/月）
GEMINI_API_KEY=your_gemini_api_key_here        # https://aistudio.google.com/app/apikey

# ── Phase 2: 可选 API Keys ─────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here        # Google Cloud Console
GOOGLE_CSE_CX=your_custom_search_engine_id    # https://programmablesearchengine.google.com
REDDIT_CLIENT_ID=your_reddit_app_id           # https://www.reddit.com/prefs/apps
REDDIT_CLIENT_SECRET=your_reddit_app_secret

# ── Miner 启用开关（1=启用，0=禁用）──────────────────────────────────
SERPER_ENABLED=1
HUNTER_ENABLED=1
GOOGLE_CSE_ENABLED=0
SEC_PH_ENABLED=0
REDDIT_ENABLED=0
PHILGEPS_ENABLED=0

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=leads
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/leads

# ── ChromaDB ───────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION=all_leads

# ── Gemini 模型 ────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_CONCURRENT=10

# ── n8n 2.x ──────────────────────────────────────────
# 首次启动自动创建 Owner 账户，无需手动完成 Setup Wizard
N8N_JWT_SECRET=n8n-super-secret-jwt-key-change-this
N8N_OWNER_EMAIL=admin@leadminer.local
N8N_OWNER_FIRST_NAME=Admin
N8N_OWNER_LAST_NAME=User
N8N_OWNER_PASSWORD=LeadMiner2024!
WEBHOOK_URL=http://localhost:5678
N8N_EDITOR_BASE_URL=http://localhost:5678

# ── SMTP（邮件发送，sales-outreach-engine 需要）──────────────────────
# Gmail 推荐使用 App Password（两步验证 → 应用专用密码）
# 申请地址：https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_here   # 16位 App Password，非登录密码
SENDER_NAME=Your Company Sales Team

# ── Sales Outreach Engine ───────────────────────────────────────────
LEAD_MINER_URL=http://lead-miner:8000
