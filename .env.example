# ─────────────────────────────────────────────────────────────────
# Lead Mining System — 环境变量模板
# 复制为 .env 并填入真实值后使用：cp .env.example .env
# ⚠️ 绝对不要将 .env 提交到 Git 仓库！
# ─────────────────────────────────────────────────────────────────

# ── Phase 1: 核心 API Keys（必填）─────────────────────────────────
SERPER_API_KEY=your_serper_api_key_here        # https://serper.dev
HUNTER_API_KEY=your_hunter_api_key_here        # https://hunter.io → Dashboard → API （免费注册，25次/月）
GEMINI_API_KEY=your_gemini_api_key_here        # https://aistudio.google.com/app/apikey

# ── Phase 2: 可选 API Keys ─────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here        # Google Cloud Console
GOOGLE_CSE_CX=your_custom_search_engine_id    # https://programmablesearchengine.google.com
REDDIT_CLIENT_ID=your_reddit_app_id           # https://www.reddit.com/prefs/apps
REDDIT_CLIENT_SECRET=your_reddit_app_secret

# ── Phase 3: 可选 API Keys ─────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=                        # https://developers.facebook.com

# ── Miner 启用开关（1=启用，0=禁用）──────────────────────────────────
SERPER_ENABLED=1
HUNTER_ENABLED=0
GOOGLE_CSE_ENABLED=0
SEC_PH_ENABLED=0
REDDIT_ENABLED=0
PHILGEPS_ENABLED=0
FACEBOOK_ENABLED=0
DTI_BNRS_ENABLED=0

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_strong_password       # ⚠️ 生产必须修改
POSTGRES_DB=leads
DATABASE_URL=postgresql://postgres:replace_with_strong_password@postgres:5432/leads

# ── ChromaDB ───────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8002                              # 宿主机访问端口（容器内部使用 8000）
CHROMA_COLLECTION=all_leads
CHROMA_AUTH_TOKEN=                            # ChromaDB 认证令牌（生产环境必填）
CHROMA_USE_SSL=false                          # 生产环境建议设为 true

# ── Gemini 模型 ────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_CONCURRENT=10

# ── 域名 & Nginx SSL ──────────────────────────────────
DOMAIN=your-domain.com

# ── n8n 2.x ──────────────────────────────────────────
N8N_JWT_SECRET=replace_with_strong_random_secret_min_32_chars   # openssl rand -hex 32
N8N_OWNER_EMAIL=admin@leadminer.local
N8N_OWNER_FIRST_NAME=Admin
N8N_OWNER_LAST_NAME=User
N8N_OWNER_PASSWORD=replace_with_strong_password                 # ⚠️ 至少16位
WEBHOOK_URL=https://n8n.your-domain.com
N8N_EDITOR_BASE_URL=https://n8n.your-domain.com
N8N_PROTOCOL=https
N8N_SECURE_COOKIE=true

# ── SMTP（邮件发送，sales-outreach-engine 需要）──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_here          # 16位 App Password，非登录密码
SENDER_NAME="Your Company Sales Team"

# ── Sales Outreach Engine ───────────────────────────────────────────
LEAD_MINER_URL=http://lead-miner:8000

# ── P3-4: 多语言外展邮件 ──────────────────────────────────────────────
OUTREACH_DEFAULT_LANGUAGE=mixed               # en | fil | mixed

# ── P3-5: CRM 对接 ────────────────────────────────────────────────
CRM_PROVIDER=none                             # none | hubspot | pipedrive
HUBSPOT_ACCESS_TOKEN=
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=api.pipedrive.com

# ── Lead Mining Admin Console ──────────────────────────────────────
ADMIN_SECRET=replace_with_strong_random_secret_min_32_chars     # openssl rand -hex 32
ADMIN_PASSWORD=replace_with_strong_admin_password               # ⚠️ 至少16位

# ── 安全：可信代理 IP（速率限制防 IP 欺骗）──────────────────────────
# 多个 IP/CIDR 以逗号分隔；留空则不信任 X-Forwarded-For
TRUSTED_PROXY_IPS=127.0.0.1,172.16.0.0/12
