# ─────────────────────────────────────────────────────────────────
# Lead Mining System — environment variable template
# Copy to .env and fill in real values before use: cp .env.example .env
# ⚠️ Never commit .env to the Git repository!
# ─────────────────────────────────────────────────────────────────

# ── Phase 1: Core API Keys (required) ───────────────────────────────────────
SERPER_API_KEY=your_serper_api_key_here        # https://serper.dev
HUNTER_API_KEY=your_hunter_api_key_here        # https://hunter.io → Dashboard → API (free registration, 25/month)
GEMINI_API_KEY=your_gemini_api_key_here        # https://aistudio.google.com/app/apikey

# ── Phase 2: Optional API Keys ──────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here        # Google Cloud Console
GOOGLE_CSE_CX=your_custom_search_engine_id    # https://programmablesearchengine.google.com
REDDIT_CLIENT_ID=your_reddit_app_id           # https://www.reddit.com/prefs/apps
REDDIT_CLIENT_SECRET=your_reddit_app_secret

# ── Phase 3: Optional API Keys ──────────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=                        # https://developers.facebook.com

# ── Miner enable switches (1=enable, 0=disable) ─────────────────────────────
SERPER_ENABLED=1
HUNTER_ENABLED=0
GOOGLE_CSE_ENABLED=0
SEC_PH_ENABLED=0
REDDIT_ENABLED=0
PHILGEPS_ENABLED=0
FACEBOOK_ENABLED=0
DTI_BNRS_ENABLED=0

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_strong_password       # ⚠️ Must be changed in production
POSTGRES_DB=leads
DATABASE_URL=postgresql://postgres:replace_with_strong_password@postgres:5432/leads

# ── ChromaDB ───────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8002                              # Host port (container internally uses 8000)
CHROMA_COLLECTION=all_leads
CHROMA_AUTH_TOKEN=                            # ChromaDB auth token (required in production)
CHROMA_USE_SSL=false                          # Recommended to set to true in production

# ── Gemini model ─────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_CONCURRENT=10

# ── Domain & Nginx SSL ──────────────────────────────────────────────────────
DOMAIN=your-domain.com

# ── n8n 2.x ──────────────────────────────────────────
N8N_JWT_SECRET=replace_with_strong_random_secret_min_32_chars   # openssl rand -hex 32
N8N_OWNER_EMAIL=admin@leadminer.local
N8N_OWNER_FIRST_NAME=Admin
N8N_OWNER_LAST_NAME=User
N8N_OWNER_PASSWORD=replace_with_strong_password                 # ⚠️ At least 16 characters
WEBHOOK_URL=https://n8n.your-domain.com
N8N_EDITOR_BASE_URL=https://n8n.your-domain.com
N8N_PROTOCOL=https
N8N_SECURE_COOKIE=true

# ── SMTP (email sending, required by sales-outreach-engine) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_here          # 16-character App Password, not your login password
SENDER_NAME="Your Company Sales Team"

# ── Sales Outreach Engine ───────────────────────────────────────────
LEAD_MINER_URL=http://lead-miner:8000

# ── P3-4: Multilingual outreach emails ──────────────────────────────────────
OUTREACH_DEFAULT_LANGUAGE=mixed               # en | fil | mixed

# ── P3-5: CRM integration ───────────────────────────────────────────────────
CRM_PROVIDER=none                             # none | hubspot | pipedrive
HUBSPOT_ACCESS_TOKEN=
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=api.pipedrive.com

# ── Lead Mining Admin Console ──────────────────────────────────────
ADMIN_SECRET=replace_with_strong_random_secret_min_32_chars     # openssl rand -hex 32
ADMIN_PASSWORD=replace_with_strong_admin_password               # ⚠️ At least 16 characters

# ── Security: trusted proxy IPs (rate limiting to prevent IP spoofing) ──────
# Multiple IPs/CIDRs comma-separated; leave empty to not trust X-Forwarded-For
TRUSTED_PROXY_IPS=127.0.0.1,172.16.0.0/12
