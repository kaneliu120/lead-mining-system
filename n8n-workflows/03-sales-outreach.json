{
  "name": "03 - Sales Outreach (LangGraph Automation)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 9 * * 1-5"
            }
          ]
        }
      },
      "id": "outreach-trigger",
      "name": "Weekdays 9AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        240,
        300
      ],
      "notes": "Trigger outreach at 9AM on weekdays (Philippines time PHT = UTC+8)"
    },
    {
      "parameters": {
        "jsCode": "// Outreach configuration\nreturn [{\n  json: {\n    limit: 20,\n    min_score: 65,\n    industry_keyword: null,\n    dry_run: false\n  }\n}];"
      },
      "id": "outreach-config",
      "name": "Outreach Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://sales-outreach:8080/outreach/run",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "limit",
              "value": "={{ $json.limit }}"
            },
            {
              "name": "min_score",
              "value": "={{ $json.min_score }}"
            },
            {
              "name": "industry_keyword",
              "value": "={{ $json.industry_keyword }}"
            },
            {
              "name": "dry_run",
              "value": "={{ $json.dry_run }}"
            }
          ]
        },
        "options": {
          "timeout": 300000
        }
      },
      "id": "trigger-outreach",
      "name": "Trigger Outreach Engine",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false
          },
          "conditions": [
            {
              "leftValue": "={{ $json.sent }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ]
        }
      },
      "id": "check-sent",
      "name": "Any Emails Sent?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://sales-outreach:8080/webhook/outreach-summary",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "sent",
              "value": "={{ $('Trigger Outreach Engine').item.json.sent }}"
            },
            {
              "name": "skipped",
              "value": "={{ $('Trigger Outreach Engine').item.json.skipped }}"
            },
            {
              "name": "failed",
              "value": "={{ $('Trigger Outreach Engine').item.json.failed }}"
            },
            {
              "name": "timestamp",
              "value": "={{ $now }}"
            }
          ]
        }
      },
      "id": "notify-success",
      "name": "Notify: Emails Sent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1120,
        220
      ],
      "notes": "Can be replaced with Telegram Bot or Slack Webhook for notifications"
    },
    {
      "parameters": {
        "jsCode": "const result = $('Trigger Outreach Engine').item.json;\nconsole.log('No emails sent today. Skipped:', result.skipped, 'Failed:', result.failed);\nreturn [{ json: { status: 'no_emails', ...result } }];"
      },
      "id": "log-no-send",
      "name": "Log: No Emails",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        400
      ]
    }
  ],
  "connections": {
    "Weekdays 9AM": {
      "main": [
        [
          {
            "node": "Outreach Config",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Outreach Config": {
      "main": [
        [
          {
            "node": "Trigger Outreach Engine",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Trigger Outreach Engine": {
      "main": [
        [
          {
            "node": "Any Emails Sent?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Any Emails Sent?": {
      "main": [
        [
          {
            "node": "Notify: Emails Sent",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Log: No Emails",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1",
    "saveExecutionProgress": true,
    "saveManualExecutions": true
  },
  "tags": [],
  "meta": {
    "description": "Auto-run LangGraph outreach flow at 9AM on weekdays: RAG retrieval → contact lookup → Gemini email generation → SMTP send"
  },
  "id": "43cff21e-094b-410b-94bb-09fff6e3592a"
}